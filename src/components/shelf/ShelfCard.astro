---
interface Props {
  title: string;
  creator: string;
  type: string;
  status: string;
  note: string;
  year?: string;
}

const { title, creator, type, status, note, year } = Astro.props;
---

<article class={`shelf-card shelf-type-${type}`}>
  <header class="shelf-card-head">
    <span class="shelf-type">{type}</span>
    <span class={`shelf-status shelf-status-${status}`}>{status}</span>
  </header>
  <h2>{title}</h2>
  <p class="shelf-creator">{creator}{year ? `, ${year}` : ""}</p>
  <p class="shelf-note">{note}</p>
</article>
