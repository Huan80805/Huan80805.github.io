---
interface Props {
  year: string;
  title: string;
  body: string;
  category: string;
  accent: string;
}

const { year, title, body, category, accent } = Astro.props;
---

<article class={`timeline-entry accent-${accent}`}>
  <span class="timeline-year">{year}</span>
  <span class="timeline-category">{category}</span>
  <h2>{title}</h2>
  <p>{body}</p>
</article>
