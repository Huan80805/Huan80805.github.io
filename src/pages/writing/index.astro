---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("writing"))
  .filter((entry) => !entry.data.draft && entry.data.listed)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const grouped = entries.reduce<Record<number, typeof entries>>((acc, entry) => {
  const year = entry.data.date.getFullYear();
  (acc[year] ||= []).push(entry);
  return acc;
}, {});
const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);

const dateFmt = new Intl.DateTimeFormat("en-US", { month: "short", day: "2-digit" });
---

<BaseLayout title="Notes | Tsung-Huan Yang" description="Course notes, essays, and reading notes by Tsung-Huan Yang">
  <section class="page-hero">
    <span class="eyebrow">Notes · {entries.length} {entries.length === 1 ? "entry" : "entries"}</span>
    <h1>Reading notes, essays, things in motion.</h1>
    <p class="lede">
      A mix of paper notes, blogs on things worth thinking about, and shorter murmurs that want to be fleshed out. Synced from Notion.
    </p>
  </section>

  {years.map((year) => (
    <section class="writing-year-block">
      <header class="writing-year-head">
        <span class="writing-year-numeral">{year}</span>
        <span class="eyebrow">
          {grouped[year].length} {grouped[year].length === 1 ? "entry" : "entries"}
        </span>
      </header>
      <div class="writing-list">
        {grouped[year].map((entry) => (
          <a class="writing-row" href={`/writing/${entry.slug}`}>
            <div class="writing-row-meta">
              <span class={`writing-type-badge writing-type-${entry.data.type}`}>
                {entry.data.type}
              </span>
              <span class="writing-row-date">{dateFmt.format(entry.data.date)}</span>
            </div>
            <div class="writing-row-main">
              <h2>{entry.data.title}</h2>
              {entry.data.tags.length > 0 && (
                <div class="tag-row">
                  {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
