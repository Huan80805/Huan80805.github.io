---

import BaseLayout from "../layouts/BaseLayout.astro";
import ShelfCard from "../components/shelf/ShelfCard.astro";
import { getCollection } from "astro:content";

const items = await getCollection("shelf");
const current = items.filter((item) => item.data.status === "now");
const archive = items.filter((item) => item.data.status !== "now");

<BaseLayout title="Shelf | Tsung-Huan Yang" description="Books, games, anime, films, and papers">
  <section class="page-hero">
    <span class="eyebrow">Shelf · {items.length} items</span>
    <h1>Current rotation, and what stayed with me.</h1>
    <p class="lede">
      A clean archive rather than a literal wooden bookshelf. Holds books, anime, films, games, and papers without
      collapsing into a novelty gimmick.
    </p>
  </section>

  <section class="now-block">
    <header class="now-head">
      <h2>Current rotation</h2>
      <span class="eyebrow">{current.length} in progress</span>
    </header>
    <div class="shelf-grid">
      {current.map((item) => <ShelfCard {...item.data} />)}
    </div>
  </section>

  <section class="now-block">
    <header class="now-head">
      <h2>Archive</h2>
      <span class="eyebrow">{archive.length} kept</span>
    </header>
    {archive.length > 0 ? (
      <div class="shelf-grid">
        {archive.map((item) => <ShelfCard {...item.data} />)}
      </div>
    ) : (
      <p class="now-empty">Nothing here yet.</p>
    )}
  </section>
</BaseLayout>
