---
import BaseLayout from "./BaseLayout.astro";

interface Link {
  label: string;
  href: string;
}

interface Props {
  title: string;
  summary: string;
  status: string;
  role?: string;
  stack?: string[];
  links?: Link[];
  date?: Date;
  thumbnail?: string;
}

const { title, summary, status, role, stack = [], links = [], date, thumbnail } = Astro.props;
const year = date ? date.getFullYear().toString() : undefined;
const heroStyle = thumbnail ? `--hero-bg: url('${thumbnail}')` : undefined;
---

<BaseLayout title={`${title} | Projects`} description={summary}>
  <article class="detail-page">
    <a href="/" class="back-link">← Home</a>

    <header class={`detail-hero${thumbnail ? " detail-hero-with-bg" : ""}`} style={heroStyle}>
      <span class="eyebrow">Project · {status}{year ? ` · ${year}` : ""}</span>
      <h1>{title}</h1>
      <p class="lede">{summary}</p>
    </header>

    <dl class="detail-meta">
      {role && (
        <div class="detail-meta-row">
          <dt>Role</dt>
          <dd>{role}</dd>
        </div>
      )}
      {stack.length > 0 && (
        <div class="detail-meta-row">
          <dt>Stack</dt>
          <dd>{stack.join(" · ")}</dd>
        </div>
      )}
      {links.length > 0 && (
        <div class="detail-meta-row">
          <dt>Links</dt>
          <dd class="detail-links">
            {links.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">{link.label} →</a>
            ))}
          </dd>
        </div>
      )}
    </dl>

    <div class="prose-block detail-prose">
      <slot />
    </div>
  </article>

  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">&#x2715;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <p class="lightbox-caption" id="lightbox-caption"></p>
  </div>
</BaseLayout>

<script>
  const lightbox = document.getElementById("lightbox") as HTMLElement | null;
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const lbCaption = document.getElementById("lightbox-caption") as HTMLElement | null;
  const lbClose = document.getElementById("lightbox-close") as HTMLElement | null;

  if (lightbox && lbImg && lbCaption && lbClose) {
    document.querySelectorAll<HTMLImageElement>(".detail-prose img").forEach((img) => {
      img.style.cursor = "zoom-in";
      img.addEventListener("click", () => {
        lbImg.src = img.src;
        lbImg.alt = img.alt;
        const caption =
          img.closest("figure")?.querySelector("figcaption")?.textContent ??
          img.alt ??
          "";
        lbCaption.textContent = caption;
        lightbox.classList.add("is-open");
      });
    });

    const close = () => lightbox.classList.remove("is-open");
    lightbox.addEventListener("click", (e) => { if (e.target === lightbox) close(); });
    lbClose.addEventListener("click", close);
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
  }
</script>
